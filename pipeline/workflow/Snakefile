# Load configuration
configfile: "/app/pipeline/config/config.yaml"

# Extract configuration values
BIDS_ROOT = config["bids_root"]
DERIVATIVES_ROOT = config["derivatives_root"]

# HSF segmentation parameters
HSF_PARAMS = config["hsf_params"]

# Hemisphere and label definitions
HEMIS = config["hemis"]
LABELS = config["labels"]

# Auto-discover subjects and sessions from BIDS structure
def discover_subjects():
    """Discover subjects and sessions from BIDS dataset"""
    pattern = os.path.join(BIDS_ROOT, "sub-*/ses-*/anat/*_T1w.nii.gz")
    files = glob.glob(pattern)
    
    subject_session_pairs = []
    
    for f in files:
        # Parse BIDS filename: sub-XX_ses-Y_T1w.nii.gz
        basename = os.path.basename(f)
        match = re.match(r'sub-([^_]+)_ses-([^_]+)_T1w\.nii\.gz', basename)
        if match:
            subject = match.group(1)
            session = match.group(2)
            if (subject, session) not in subject_session_pairs:
                subject_session_pairs.append((subject, session))
    
    # Separate into subjects and sessions lists for backward compatibility
    subjects = [pair[0] for pair in subject_session_pairs]
    sessions = [pair[1] for pair in subject_session_pairs]
    
    return subjects, sessions, subject_session_pairs

# Get subjects and sessions
SUBJECTS, SESSIONS, SUBJECT_SESSION_PAIRS = discover_subjects()

# Helper function to get input path
def get_input_path(subject, session):
    """Get the input T1w file path for a subject and session"""
    return os.path.join(BIDS_ROOT, f"sub-{subject}", f"ses-{session}", "anat",
            f"sub-{subject}_ses-{session}_T1w.nii.gz")

def hsf_output(subject, session):
    """Path to the combined HSF segmentation output."""
    return os.path.join(
        DERIVATIVES_ROOT,
        f"sub-{subject}",
        f"ses-{session}",
        "anat",
        f"sub-{subject}_ses-{session}_space-T1w_desc-hsf_dseg.nii.gz",
    )

def hsf_left_crop_output(subject, session):
    """Path to the left cropped segmentation output produced by HSF."""
    return get_seg_crop_output(subject, session, "L")

def hsf_right_crop_output(subject, session):
    """Path to the right cropped segmentation output produced by HSF."""
    return get_seg_crop_output(subject, session, "R")

def get_seg_crop_output(subject, session, hemi):
    """Path to cropped segmentation produced by HSF (per hemisphere)."""
    return os.path.join(
        DERIVATIVES_ROOT,
        f"sub-{subject}",
        f"ses-{session}",
        "anat",
        f"sub-{subject}_ses-{session}_space-T1w_desc-hsf_hemi-{hemi}_seg_crop.nii.gz",
    )

def label_mask_output(subject, session, hemi, label):
    """Path to per-label mask for a hemisphere."""
    return os.path.join(
        DERIVATIVES_ROOT,
        f"sub-{subject}",
        f"ses-{session}",
        "anat",
        f"sub-{subject}_ses-{session}_space-T1w_desc-hsf_hemi-{hemi}_label-{label}_mask.nii.gz",
    )

def combined_mask_output(subject, session, hemi):
    """Path to combined hippocampus mask (all labels merged) for a hemisphere."""
    return os.path.join(
        DERIVATIVES_ROOT,
        f"sub-{subject}",
        f"ses-{session}",
        "anat",
        f"sub-{subject}_ses-{session}_space-T1w_desc-hsf_hemi-{hemi}_mask.nii.gz",
    )

