import os
import glob
import re
import sys
from pathlib import Path
from scripts.nii_parse import split_one_label, combine_labels

# Load configuration
configfile: "/app/pipeline/config/config.yaml"

# Extract configuration values
BIDS_ROOT = config["bids_root"]
DERIVATIVES_ROOT = config["derivatives_root"]

# HSF segmentation parameters
HSF_PARAMS = config["hsf_params"]

# Hemisphere and label definitions
HEMIS = config["hemis"]
LABELS = config["labels"]

