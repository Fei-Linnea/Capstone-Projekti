import os
import glob
import re
from pathlib import Path

# Load configuration
configfile: "/app/config/config.yaml"

# Extract configuration values
BIDS_ROOT = config["bids_root"]
DERIVATIVES_ROOT = config["derivatives_root"]

# HSF segmentation parameters
HSF_PARAMS = config.get("hsf_params", {
    "contrast": "t1",
    "margin": "[8,8,8]",
    "segmentation_mode": "single_fast",
    "ca_mode": "1/2/3"
})

# Auto-discover subjects and sessions from BIDS structure
def discover_subjects():
    """Discover subjects and sessions from BIDS dataset"""
    pattern = os.path.join(BIDS_ROOT, "sub-*/ses-*/anat/*_T1w.nii.gz")
    files = glob.glob(pattern)
    
    subjects = []
    sessions = []
    
    for f in files:
        # Parse BIDS filename: sub-XX_ses-Y_T1w.nii.gz
        basename = os.path.basename(f)
        match = re.match(r'sub-([^_]+)_ses-([^_]+)_T1w\.nii\.gz', basename)
        if match:
            subjects.append(match.group(1))
            sessions.append(match.group(2))
    
    return subjects, sessions

# Get subjects and sessions
SUBJECTS, SESSIONS = discover_subjects()

# Helper function to get input path
def get_input_path(subject, session):
    """Get the input T1w file path for a subject and session"""
    return os.path.join(BIDS_ROOT, f"sub-{subject}", f"ses-{session}", "anat",
                       f"sub-{subject}_ses-{session}_T1w.nii.gz")

# Include rules
include: "rules/hsf_segmentation.smk"

# Define all output files
rule all:
    input:
        expand(
            os.path.join(DERIVATIVES_ROOT, "sub-{subject}", "ses-{session}", "anat",
                        "sub-{subject}_ses-{session}_space-T1w_desc-hsf_dseg.nii.gz"),
            zip,
            subject=SUBJECTS,
            session=SESSIONS
        )
