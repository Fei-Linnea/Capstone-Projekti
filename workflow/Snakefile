# Snakefile - Simple Hippodeep Pipeline

import os
from pathlib import Path
import glob

# Get input data directory
DATA_DIR = config.get("data_dir", "data/input")

# Get all .nii.gz files and extract their relative paths
all_nii_files = glob.glob(os.path.join(DATA_DIR, "**/*.nii.gz"), recursive=True)

# Extract relative paths from DATA_DIR
INPUT_FILES = [os.path.relpath(f, DATA_DIR) for f in all_nii_files]

# Extract just the filename without extension for the subject wildcard
# Remove both .nii.gz extensions
SUBJECTS = [os.path.splitext(os.path.splitext(os.path.basename(f))[0])[0] for f in INPUT_FILES]

rule all:
    input:
        expand("results/hippodeep/{subject}_left.nii.gz", subject=SUBJECTS)

# Single rule: Run Hippodeep
rule hippodeep:
    input:
        lambda wildcards: [os.path.join(DATA_DIR, f) for f in INPUT_FILES if os.path.splitext(os.path.splitext(os.path.basename(f))[0])[0] == wildcards.subject][0]
    output:
        left = "results/hippodeep/{subject}_left.nii.gz",
        right = "results/hippodeep/{subject}_right.nii.gz"
    log:
        "logs/hippodeep/{subject}.log"
    shell:
        """
        mkdir -p results/hippodeep
        mkdir -p $(dirname {log})
        
        # Get absolute path to output directory
        output_dir=$(cd results/hippodeep && pwd)
        
        # Get the base filename
        base_name=$(basename {input} .nii.gz)
        input_dir=$(dirname {input})
        
        echo "Running Hippodeep on {input}..." > {log}
        echo "Input directory: $input_dir" >> {log}
        echo "Output directory: $output_dir" >> {log}
        echo "Base name: $base_name" >> {log}
        
        # Run hippodeep in the input directory
        cd "$input_dir"
        python /opt/hippodeep/hippodeep.py "$base_name.nii.gz" 2>> /app/{log}
        
        echo "Hippodeep finished with exit code: $?" >> /app/{log}
        
        # List files created in input directory
        echo "Files in input directory after hippodeep:" >> /app/{log}
        ls -la "$input_dir" | grep -E "mask|nii" >> /app/{log}
        
        # Move the output files - Hippodeep creates _mask_L.nii.gz and _mask_R.nii.gz
        if [ -f "${{input_dir}}/${{base_name}}_mask_L.nii.gz" ]; then
            mv "${{input_dir}}/${{base_name}}_mask_L.nii.gz" "${{output_dir}}/{wildcards.subject}_left.nii.gz"
            echo "Moved left mask: ${{base_name}}_mask_L.nii.gz -> ${{output_dir}}/{wildcards.subject}_left.nii.gz" >> /app/{log}
        else
            echo "ERROR: Left mask file not found at ${{input_dir}}/${{base_name}}_mask_L.nii.gz" >> /app/{log}
            touch "${{output_dir}}/{wildcards.subject}_left.nii.gz"
        fi
        
        if [ -f "${{input_dir}}/${{base_name}}_mask_R.nii.gz" ]; then
            mv "${{input_dir}}/${{base_name}}_mask_R.nii.gz" "${{output_dir}}/{wildcards.subject}_right.nii.gz"
            echo "Moved right mask: ${{base_name}}_mask_R.nii.gz -> ${{output_dir}}/{wildcards.subject}_right.nii.gz" >> /app/{log}
        else
            echo "ERROR: Right mask file not found at ${{input_dir}}/${{base_name}}_mask_R.nii.gz" >> /app/{log}
            touch "${{output_dir}}/{wildcards.subject}_right.nii.gz"
        fi
        
        echo "Done!" >> /app/{log}
        """